# ════════════════════════════════════════════════
# BLIPS BOS — Git ignore
# ════════════════════════════════════════════════

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependencies
node_modules/
.pnp
.pnp.js
.pnpm-debug.log*

# REVIEW.md F16+F28 (May 18, 2026): pnpm-only project (lockfileVersion 9.x).
# package-lock.json is the npm artifact; if a contributor accidentally runs
# `npm install` the preinstall hook (only-allow pnpm) refuses + we never
# want package-lock.json to slip back into the repo.
package-lock.json

# Build output
.next/
out/
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
.nyc_output

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Drizzle migrations cache (keep the actual migrations, ignore temp files)
.drizzle/

# Local-only scripts or notes
scratch/
TODO.local.md
.claude/

# Vercel CLI cache
.vercel/
